{
  "name": "qa-automation-cicd-pipeline",
  "version": "1.0.0",
  "description": "Pipeline CI/CD de nivel Sr sobre una suite combinada UI + API con Playwright. Portfolio QA Automation Sr.",
  "author": "Fernando Carballo",
  "license": "MIT",
  "scripts": {
    "test": "playwright test",
    "test:pr": "playwright test --grep @smoke --project=chromium --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:ui": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:api": "playwright test --project=api",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "ci-cd",
    "github-actions",
    "qa-automation",
    "test-automation"
  ],
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.19.0"
  },
  "dependencies": {
    "zod": "^3.24.0"
  }
}
